{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "advantagescope",
  "version": "0.1.0",
  "identifier": "org.advantagescope.advantagescope",
  "build": {
    "frontendDist": "..",
    "devUrl": "http://localhost:5808",
    "beforeDevCommand": "npm run watch",
    "beforeBuildCommand": "npm run compile"
  },
  "app": {
    "windows": [
      {
        "title": "advantagescope",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
